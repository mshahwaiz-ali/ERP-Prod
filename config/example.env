# Copy values into your private .env or deployment environment.
# Do not put real secrets in this example file.

BENCH_DIR=./frappe-bench
FRAPPE_BRANCH=version-15
NODE_MAJOR=24

# Production deployment
PRODUCTION_DOMAIN=erp.example.com
PRODUCTION_SITE=erp.example.com
LETSENCRYPT_EMAIL=admin@example.com
APP_NAME=ledgix_saas

# Optional. Prefer entering or generating this interactively.
FRAPPE_ADMIN_PASSWORD=

# FBR tokens belong in site settings or private environment only.
FBR_SANDBOX_TOKEN=
FBR_PRODUCTION_TOKEN=
