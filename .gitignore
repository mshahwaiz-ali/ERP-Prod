# Installed/generated Frappe bench. Recreated by install.sh or deploy scripts.
frappe-bench/
/frappe-bench/

# Runtime output and logs.
logs/
backups/
/offline_bundle/
*.log
*.pid
.expose-state

# Secrets and machine-specific config.
.env
.env.*
*.env.local
config/*.env
!config/example.env
docs/private/secrets.md
deploy/production.secrets.md
deploy/backups-index.md
*.backup.*
*.sql
*.sql.gz
*.sqlite
*.sqlite3
*.tar
*.tgz

# Local editor/agent state.
.codex/
.agents/

# Python/Node/build caches.
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
dist/
build/
apps/*/build/
apps/*.egg-info/
apps/*/*.egg-info/

# Frappe site backups.
frappe-bench/sites/*/private/backups/

# Local generated secrets.
.secrets/
